# ── Supabase (optional — app works offline without these) ──────────────────────
# Create a project at https://supabase.com, run the migrations in
# supabase/migrations/ in order, then paste the URL + anon key here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Map basemap (optional) ──────────────────────────────────────────────────────
# Full MapLibre style URL, e.g. a self-hosted Protomaps/PMTiles of Venezuela.
# Leave blank to render markers on a blank background (still fully functional).
NEXT_PUBLIC_MAP_STYLE_URL=

# ── Venezuela Ayuda hub (optional) ─────────────────────────────────────────────
# Override the national hub base URL for staging or a self-hosted instance.
# Defaults to the production hub at https://terremoto.hazlohoy.org
# The hub GET endpoint is open — no API key required for reading.
# NEXT_PUBLIC_HUB_API_URL=https://terremoto.hazlohoy.org

# ── App URL (used in sitemap + OG meta) ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://reporte.ve
